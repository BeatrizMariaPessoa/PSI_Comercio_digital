{
    "version": 2,
    "builds": [
        {
            "src": "manage.py",
            "use": "@vercel/python"
        },
        {
            "src": "lojaAdmin/wsgi.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "lojaAdmin/wsgi.py"
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/"
        }
    ]
}